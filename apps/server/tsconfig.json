{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "sourceMap": true,
    "inlineSources": true,
    "paths": {
      "@actions/*": ["./src/game/actions/*"],
      "@engine/*": ["./src/game/engine/*"],
      "@cards/*": ["./src/game/cards/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
